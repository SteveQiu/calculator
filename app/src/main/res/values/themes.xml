<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Calculator" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:navigationBarColor">@color/colorBackground</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Base button style -->
    <style name="Widget.Calculator.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textSize">26sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="cornerRadius">50dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">2dp</item>
    </style>

    <style name="Widget.Calculator.Button.Number">
        <item name="backgroundTint">@color/colorBtnNumber</item>
        <item name="android:textColor">@color/colorTextOnNumber</item>
    </style>

    <style name="Widget.Calculator.Button.Special">
        <item name="backgroundTint">@color/colorBtnSpecial</item>
        <item name="android:textColor">@color/colorTextOnSpecial</item>
    </style>

    <style name="Widget.Calculator.Button.Operator">
        <item name="backgroundTint">@color/colorBtnOperator</item>
        <item name="android:textColor">@color/colorTextOnOperator</item>
    </style>

    <style name="Widget.Calculator.Button.Ghost">
        <item name="backgroundTint">@color/colorGhost</item>
        <item name="android:textColor">@color/colorTextSecondary</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="rippleColor">@color/colorBtnSpecial</item>
    </style>

    <!-- ═══════════════════════════════════════════════════
         THEME OVERLAYS — applied programmatically at runtime
         ═══════════════════════════════════════════════════ -->

    <style name="ThemeOverlay.Calculator.Midnight" parent="">
        <item name="android:colorBackground">@color/midnight_background</item>
        <item name="colorBackground">@color/midnight_background</item>
        <item name="colorBtnNumber">@color/midnight_btn_number</item>
        <item name="colorBtnSpecial">@color/midnight_btn_special</item>
        <item name="colorBtnOperator">@color/midnight_btn_operator</item>
        <item name="colorTextPrimary">@color/midnight_text_primary</item>
        <item name="colorTextSecondary">@color/midnight_text_secondary</item>
        <item name="colorTextOnNumber">@color/midnight_text_on_number</item>
        <item name="colorTextOnSpecial">@color/midnight_text_on_special</item>
        <item name="colorTextOnOperator">@color/midnight_text_on_operator</item>
    </style>

    <style name="ThemeOverlay.Calculator.Ocean" parent="">
        <item name="android:colorBackground">@color/ocean_background</item>
        <item name="colorBackground">@color/ocean_background</item>
        <item name="colorBtnNumber">@color/ocean_btn_number</item>
        <item name="colorBtnSpecial">@color/ocean_btn_special</item>
        <item name="colorBtnOperator">@color/ocean_btn_operator</item>
        <item name="colorTextPrimary">@color/ocean_text_primary</item>
        <item name="colorTextSecondary">@color/ocean_text_secondary</item>
        <item name="colorTextOnNumber">@color/ocean_text_on_number</item>
        <item name="colorTextOnSpecial">@color/ocean_text_on_special</item>
        <item name="colorTextOnOperator">@color/ocean_text_on_operator</item>
    </style>

    <style name="ThemeOverlay.Calculator.Sunset" parent="">
        <item name="android:colorBackground">@color/sunset_background</item>
        <item name="colorBackground">@color/sunset_background</item>
        <item name="colorBtnNumber">@color/sunset_btn_number</item>
        <item name="colorBtnSpecial">@color/sunset_btn_special</item>
        <item name="colorBtnOperator">@color/sunset_btn_operator</item>
        <item name="colorTextPrimary">@color/sunset_text_primary</item>
        <item name="colorTextSecondary">@color/sunset_text_secondary</item>
        <item name="colorTextOnNumber">@color/sunset_text_on_number</item>
        <item name="colorTextOnSpecial">@color/sunset_text_on_special</item>
        <item name="colorTextOnOperator">@color/sunset_text_on_operator</item>
    </style>

    <style name="ThemeOverlay.Calculator.Rabbit" parent="">
        <item name="android:colorBackground">@color/rabbit_background</item>
        <item name="colorBackground">@color/rabbit_background</item>
        <item name="colorBtnNumber">@color/rabbit_btn_number</item>
        <item name="colorBtnSpecial">@color/rabbit_btn_special</item>
        <item name="colorBtnOperator">@color/rabbit_btn_operator</item>
        <item name="colorTextPrimary">@color/rabbit_text_primary</item>
        <item name="colorTextSecondary">@color/rabbit_text_secondary</item>
        <item name="colorTextOnNumber">@color/rabbit_text_on_number</item>
        <item name="colorTextOnSpecial">@color/rabbit_text_on_special</item>
        <item name="colorTextOnOperator">@color/rabbit_text_on_operator</item>
    </style>

    <style name="ThemeOverlay.Calculator.Panda" parent="">
        <item name="android:colorBackground">@color/panda_background</item>
        <item name="colorBackground">@color/panda_background</item>
        <item name="colorBtnNumber">@color/panda_btn_number</item>
        <item name="colorBtnSpecial">@color/panda_btn_special</item>
        <item name="colorBtnOperator">@color/panda_btn_operator</item>
        <item name="colorTextPrimary">@color/panda_text_primary</item>
        <item name="colorTextSecondary">@color/panda_text_secondary</item>
        <item name="colorTextOnNumber">@color/panda_text_on_number</item>
        <item name="colorTextOnSpecial">@color/panda_text_on_special</item>
        <item name="colorTextOnOperator">@color/panda_text_on_operator</item>
    </style>

    <!-- Theme Picker Activity style -->
    <style name="Theme.Calculator.ThemePicker" parent="Theme.Calculator">
        <item name="android:windowAnimationStyle">@style/Animation.Calculator.Slide</item>
    </style>

    <style name="Animation.Calculator.Slide" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@android:anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@android:anim/slide_out_right</item>
    </style>

</resources>
