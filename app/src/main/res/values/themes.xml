<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Calculator" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:navigationBarColor">@color/colorBackground</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Base button style -->
    <style name="Widget.Calculator.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textSize">26sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="cornerRadius">50dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">2dp</item>
    </style>

    <style name="Widget.Calculator.Button.Number">
        <item name="backgroundTint">@color/colorBtnNumber</item>
        <item name="android:textColor">@color/colorTextOnNumber</item>
    </style>

    <style name="Widget.Calculator.Button.Special">
        <item name="backgroundTint">@color/colorBtnSpecial</item>
        <item name="android:textColor">@color/colorTextOnSpecial</item>
    </style>

    <style name="Widget.Calculator.Button.Operator">
        <item name="backgroundTint">@color/colorBtnOperator</item>
        <item name="android:textColor">@color/colorTextOnOperator</item>
    </style>

    <style name="Widget.Calculator.Button.Ghost">
        <item name="backgroundTint">@color/colorGhost</item>
        <item name="android:textColor">@color/colorTextSecondary</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="rippleColor">@color/colorBtnSpecial</item>
    </style>

</resources>
