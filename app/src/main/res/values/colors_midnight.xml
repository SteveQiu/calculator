    <color name="midnight_btn_operator">#7B61FF</color>
    <color name="midnight_text_primary">#E8E8FF</color>
    <color name="midnight_text_secondary">#6B6B9B</color>
    <color name="midnight_text_on_number">#E8E8FF</color>
    <color name="midnight_text_on_special">#A0A0C8</color>
    <color name="midnight_text_on_operator">#FFFFFF</color>
    <color name="midnight_ghost">#00000000</color>
    <color name="midnight_display_bg">#0D0D1A</color>
</resources>
