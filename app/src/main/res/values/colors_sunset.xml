    <color name="sunset_btn_special">#251010</color>
    <color name="sunset_btn_operator">#FF6B6B</color>
    <color name="sunset_text_primary">#FFD5C8</color>
    <color name="sunset_text_secondary">#C08070</color>
    <color name="sunset_text_on_number">#FFD5C8</color>
    <color name="sunset_text_on_special">#D09080</color>
    <color name="sunset_text_on_operator">#FFFFFF</color>
    <color name="sunset_ghost">#00000000</color>
    <color name="sunset_display_bg">#1A0A0A</color>
</resources>
