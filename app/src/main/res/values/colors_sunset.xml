<?xml version="1.0" encoding="utf-8"?>
<!--
    Sunset theme color definitions.
    These are the canonical source for the Sunset palette.
    Values are also declared in colors.xml with the sunset_ prefix.
    This file exists so style previews and tools can reference a
    self-contained, named-theme resource set.
-->
