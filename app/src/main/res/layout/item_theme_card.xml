<?xml version="1.0" encoding="utf-8"?>
<!--
    Single theme card shown in the 2-column theme picker grid.
    The host RecyclerView adapter must:
      - Populate ivPalette dots with theme colors
      - Show/hide lockOverlay based on locked state
      - Highlight cardRoot with a colored stroke when selected
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardElevation="4dp"
    app:cardCornerRadius="16dp"
    app:strokeWidth="2dp"
    app:strokeColor="@android:color/transparent"
    android:foreground="?attr/selectableItemBackground">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Card body -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Mini palette preview — three colored circles (operator, number, special) -->
            <LinearLayout
                android:id="@+id/paletteRow"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp">

                <!-- Background swatch fills the whole area -->
                <FrameLayout
                    android:id="@+id/previewBg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_theme_preview_card">

                    <!-- Mini button row: three colored circles -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <View
                            android:id="@+id/dotSpecial"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_margin="4dp"
                            android:background="@drawable/shape_palette_dot" />

                        <View
                            android:id="@+id/dotNumber"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_margin="4dp"
                            android:background="@drawable/shape_palette_dot" />

                        <View
                            android:id="@+id/dotOperator"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_margin="4dp"
                            android:background="@drawable/shape_palette_dot" />

                    </LinearLayout>
                </FrameLayout>

            </LinearLayout>

            <!-- Theme name -->
            <TextView
                android:id="@+id/tvThemeName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary"
                android:gravity="center" />

            <!-- Free / Premium badge -->
            <TextView
                android:id="@+id/tvBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="2dp"
                android:textSize="11sp"
                android:textColor="@color/colorTextSecondary"
                android:gravity="center" />

        </LinearLayout>

        <!-- Lock overlay — visible only when theme is locked.
             Contains lock icon + inline unlock CTAs so the user can act without a separate dialog. -->
        <LinearLayout
            android:id="@+id/lockOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#CC000000"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒"
                android:textSize="22sp" />

            <!-- Watch Ad — free unlock -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCardWatchAd"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:layout_marginTop="6dp"
                android:text="@string/watch_ad_to_unlock"
                android:textSize="10sp"
                android:textColor="@android:color/white"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:strokeColor="@android:color/white"
                app:strokeWidth="1dp"
                app:cornerRadius="16dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <!-- Buy — paid unlock -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCardBuy"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:layout_marginTop="4dp"
                android:text="@string/buy_to_unlock"
                android:textSize="10sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="16dp"
                style="@style/Widget.Calculator.Button.Operator" />

        </LinearLayout>

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>
